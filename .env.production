# ── Domain ──
# Your domain name (Caddy will auto-obtain Let's Encrypt certificate)
DOMAIN=analytics.example.com

# ── PostgreSQL ──
POSTGRES_DB=zaga_analytics
POSTGRES_USER=zaga
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# ── Backend ──
# Secret key for JWT tokens (generate with: openssl rand -hex 32)
ZAGA_SECRET_KEY=CHANGE_ME_run_openssl_rand_hex_32
